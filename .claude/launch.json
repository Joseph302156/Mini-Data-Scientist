{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port ${PORT:-8000}"],
      "port": 8000
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npx vite --port ${PORT:-5173} --host 0.0.0.0"],
      "port": 5173
    }
  ]
}
